# Configuração de ambiente para o Sistema de Captura de Ofertas
# Renomeie este arquivo para .env e preencha com seus próprios valores.

# --- Scrapers ---
# Deixe a URL em branco para desativar o scraper correspondente.
MAGAZINE_LUIZA_URL="https://www.magazinevoce.com.br/magazineachadostecbr/selecao/ofertasdodia/?filters=category---IN--ET--TE--GA--EA--TB--CI&page=1&sortOrientation=desc&sortType=soldQuantity"
MAGAZINE_LUIZA_COUPONS_URL="https://especiais.magazineluiza.com.br/magazinevoce/cupons/?showcase=magazineachadostecbr"
MERCADO_LIVRE_URL="https://www.mercadolivre.com.br/ofertas"
MERCADO_LIVRE_CLIENT_ID="SEU_CLIENT_ID_MERCADO_LIVRE"
MERCADO_LIVRE_CLIENT_SECRET="SEU_CLIENT_SECRET_MERCADO_LIVRE"
MERCADO_LIVRE_REDIRECT_URI="SUA_REDIRECT_URI_AQUI"


# --- Social Media ---
# Ative ou desative os posters alterando para "true" ou "false"
POST_TO_WHATSAPP="true"
POST_TO_INSTAGRAM="true"
POST_TO_FACEBOOK="true"

# --- Credenciais Meta (Facebook & Instagram) ---
# IMPORTANTE: Coloque o TOKEN DE ACESSO (começa com EAA...), NÃO o App ID ou App Secret.
FACEBOOK_ACCESS_TOKEN="SEU_TOKEN_DE_ACESSO_DA_PAGINA"
FACEBOOK_PAGE_ID="ID_DA_SUA_PAGINA_FACEBOOK"
INSTAGRAM_ACCESS_TOKEN="SEU_TOKEN_DE_ACESSO_INSTAGRAM"
INSTAGRAM_ACCOUNT_ID="ID_DA_CONTA_BUSINESS_INSTAGRAM"

# Configurações para a Evolution API (WhatsApp)
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="SUA_CHAVE_API_AQUI"
EVOLUTION_INSTANCE_NAME="NOME_DA_SUA_INSTANCIA"
WHATSAPP_CHAT_ID="ID_DO_GRUPO_OU_USUARIO@g.us"

# --- Ambiente ---
# Defina como "test" para usar o grupo de teste. Padrão: "production"
APP_ENV="production"
WHATSAPP_CHAT_ID_TEST="ID_DO_GRUPO_TESTE@g.us"
WHATSAPP_ERROR_GROUP_ID="ID_DO_GRUPO_DE_ERROS@g.us"

# Em uma implementação real, você adicionaria as chaves de API para Instagram e Facebook aqui
# INSTAGRAM_ACCESS_TOKEN="..."
# FACEBOOK_PAGE_ACCESS_TOKEN="..."

# --- Filtros ---
# Defina um valor mínimo (em Reais) para postar a oferta. Deixe em branco ou 0 para desativar.
MIN_PRICE_TO_POST=10.00

# --- Filtros Shopee ---
SHOPEE_MIN_SALES=20
SHOPEE_MIN_RATING=4.0

# --- Review Mode (Encaminhamento para Grupo de Curadoria) ---
# Se "true", nenhuma postagem vai para as redes sociais. Tudo é enviado para o grupo de revisão.
REVIEW_MODE="false"
WHATSAPP_REVIEW_GROUP_ID="120363427969171009@g.us"
WHATSAPP_STORY_REVIEW_GROUP_ID="ID_DO_GRUPO_DE_REVISAO_DE_STORIES@g.us"
